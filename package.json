{
  "name": "novel-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "novel-cli": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx source/cli.tsx",
    "dev:watch": "tsx watch --exclude output --exclude dist source/cli.tsx",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ink": "^5.2.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.80.1",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
